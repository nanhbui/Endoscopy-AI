# Git
.git
.gitignore

# Claudekit symlinks (point to host-only paths → broken inside container)
**/.claude

# Python
__pycache__
*.pyc
*.pyo
.venv
*.egg-info

# Node
frontend/node_modules
frontend/.next
frontend/logs

# Data (mounted as volumes; do NOT bake into image)
data/
sample_code/

# Model weights — block root-level + scratch artifacts, but explicitly bake
# the curated `models/` directory into the backend image so a fresh
# `docker run` works without a separate weights-download step.
*.onnx
*.trt
/yolov8n.pt
!models/*.pt
!models/*.torchscript

# Logs
logs/
*.log

# Env files (injected via docker-compose env_file)
.env
.env.local
src/backend/api/.env
frontend/.env.local

# Dev artifacts
plans/
docs/
*.md
tests/
configs/
